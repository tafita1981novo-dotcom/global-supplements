modules = ["nodejs-20", "web", "python-3.11", "postgresql-16"]
[agent]
expertMode = true
integrations = ["github:1.0.0"]

[nix]
channel = "stable-25_05"
packages = ["zip", "git-lfs", "supabase-cli"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Server"

[[workflows.workflow]]
name = "Server"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd projeto-copia && ./inject-secrets.sh && npm start"
waitForPort = 5000

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 34331
externalPort = 3000

[[ports]]
localPort = 44153
externalPort = 3001

[deployment]
deploymentTarget = "autoscale"
build = ["sh", "-c", "npm install --prefix projeto-copia && npm run build --prefix projeto-copia"]
run = ["sh", "-c", "npm start --prefix projeto-copia"]
